# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecg_insight

# Secret used to sign short-lived JWT access tokens. Use at least 32 random characters.
JWT_SECRET=replace-with-at-least-32-random-characters

# Separate secret used to sign refresh tokens. Use at least 32 random characters.
JWT_REFRESH_SECRET=replace-with-a-different-32-random-character-secret

# Runtime mode. Supported values: development, test, production.
NODE_ENV=development

# Port for the ECG Insight Express API.
PORT=3001

# Frontend origin allowed to send credentialed API requests.
CLIENT_ORIGIN=http://localhost:8081

# Optional cookie domain for refresh-token cookies. Leave blank for localhost.
COOKIE_DOMAIN=

# Public API base URL used by the Expo frontend.
EXPO_PUBLIC_API_URL=http://localhost:3001/api
