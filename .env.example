# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecg_insight

# Database container values used by docker-compose.production.yml.
POSTGRES_DB=ecg_insight
POSTGRES_USER=ecg_insight
POSTGRES_PASSWORD=replace-with-strong-database-password

# Secret used to sign short-lived JWT access tokens. Use at least 32 random characters.
JWT_SECRET=replace-with-at-least-32-random-characters

# Separate secret used to sign refresh tokens. Use at least 32 random characters.
JWT_REFRESH_SECRET=replace-with-a-different-32-random-character-secret

# Runtime mode. Supported values: development, test, production.
NODE_ENV=development

# Port for the ECG Insight Express API.
PORT=3002

# Frontend origin allowed to send credentialed API requests.
# Use comma-separated HTTPS origins in production.
CLIENT_ORIGIN=http://localhost:8081

# Optional cookie domain for refresh-token cookies. Leave blank for localhost.
COOKIE_DOMAIN=

# Public API base URL used by the Expo frontend.
EXPO_PUBLIC_API_URL=http://localhost:3002/api

# Optional alias for Vite/web tooling. ECG Insight Expo runtime uses EXPO_PUBLIC_API_URL.
VITE_API_URL=http://localhost:3002/api

# Structured logging level: debug, info, warn, or error.
LOG_LEVEL=info

# Optional external exception monitoring DSN.
EXCEPTION_MONITORING_DSN=

# Optional ONNX model path. If omitted, the API checks ai-engine/runs/first-real-ecg-model/model.onnx,
# ai-engine/artifacts/model.onnx, then ai-engine/model.onnx.
AI_ONNX_MODEL_PATH=

# API rate limiting configuration.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600

# Set true when running behind a trusted reverse proxy/load balancer.
TRUST_PROXY=false
