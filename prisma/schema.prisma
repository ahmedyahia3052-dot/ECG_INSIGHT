model User {
  id                          String                    @id @default(cuid())
  name                        String
  email                       String                    @unique
  username                    String?                   @unique
  phoneNumber                 String?                   @unique
  phoneVerified               Boolean                   @default(false)
  passwordHash                String
  role                        Role                      @default(STUDENT)
  protectedOwner              Boolean                   @default(false)
  ownerPasswordSetupRequired  Boolean                   @default(false)
  ownerTwoFactorRequired      Boolean                   @default(false)
  specialization              String?
  licenseNumber               String?
  institution                 String?
  avatarInitials              String
  isActive                    Boolean                   @default(true)
  isLifetime                  Boolean                   @default(false)
  lifetimeGrantedAt           DateTime?
  lifetimeGrantedBy           String?
  lifetimeRevokedAt           DateTime?
  lifetimeRevokedBy           String?
  emailVerified               Boolean                   @default(false)
  emailVerificationTokenHash  String?
  emailVerificationExpiresAt  DateTime?
  passwordResetTokenHash      String?
  passwordResetExpiresAt      DateTime?
  failedLoginAttempts         Int                       @default(0)
  lockedUntil                 DateTime?
  forcePasswordReset          Boolean                   @default(false)
  passwordChangedAt           DateTime                  @default(now())
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  sessions                    Session[]
  oauthIdentities             OAuthIdentity[]
  phoneOtps                   PhoneOtp[]
  subscription                Subscription?
  commercialSubscriptions     UserSubscription[]
  licenses                    License[]                  @relation("LicenseUser")
  grantedLicenses             License[]                  @relation("LicenseGrantedBy")
  revokedLicenses             License[]                  @relation("LicenseRevokedBy")
  payments                    Payment[]
  paymentTransactions         PaymentTransaction[]
  giftLicenses                GiftLicense[]             @relation("GiftLicenseUser")
  giftedLicenses              GiftLicense[]             @relation("GiftLicenseGiftedBy")
  usageRecords                UsageRecord[]
  billingEvents               BillingEvent[]
  notifications               Notification[]
  uploadedCases               ECGCase[]                 @relation("UploadedCases")
  assignedCases               ECGCase[]                 @relation("AssignedCases")
  auditLogs                   AuditLog[]
  fitnessDecisions            FitnessDecision[]
  authoredReports             ClinicalReport[]          @relation("AuthoredReports")
  finalizedReports            ClinicalReport[]          @relation("FinalizedReports")
  signedReports               ClinicalReport[]          @relation("SignedReports")
  reportVersions              ReportVersion[]
  reportSignatures            ReportSignature[]
  sentEmails                  EmailLog[]                @relation("SentReportEmails")
  fitnessAssessments          FitnessAssessment[]       @relation("FitnessAssessmentPhysician")
  returnToWorkDecisions       ReturnToWorkDecision[]    @relation("ReturnToWorkPhysician")
  reviewedDocumentExtractions DocumentExtraction[]      @relation("ReviewedDocumentExtractions")
  knowledgeArticles           KnowledgeArticle[]
  pacsConnections             PACSConnection[]
  hospitalIntegrationLogs     HospitalIntegrationLog[]
  requestedTelecardiology     TelecardiologyReview[]    @relation("TelecardiologyRequestedBy")
  assignedTelecardiology      TelecardiologyReview[]    @relation("TelecardiologyAssignedTo")
  signedTelecardiology        TelecardiologyReview[]    @relation("TelecardiologySignedBy")
  clinicalConversations       ClinicalConversation[]
  riskAssessments             RiskAssessment[]
  createdClinicalAlerts       ClinicalAlert[]           @relation("ClinicalAlertCreatedBy")
  acknowledgedClinicalAlerts  ClinicalAlert[]           @relation("ClinicalAlertAcknowledgedBy")
  enterpriseSessions          UserSession[]
  mfaMethods                  UserMFA[]
  passwordHistory             PasswordHistory[]
  trustedDevices              TrustedDevice[]
  rolePermissions             RolePermission[]
  securityEvents              SecurityEvent[]
  patientConsents             PatientConsent[]
  dataRequests                DataRequest[]
  backupJobs                  BackupJob[]
  syncQueueItems              SyncQueue[]
  offlineCaches               OfflineCache[]
  createdTasks                Task[]                    @relation("TaskCreatedBy")
  assignedTaskLinks           TaskAssignment[]
  taskComments                TaskComment[]
  teamMemberships             TeamMember[]
  createdTeams                Team[]                    @relation("TeamCreatedBy")
  conversationMemberships     ConversationParticipant[]
  sentMessages                Message[]                 @relation("MessageSender")
  readReceipts                MessageReadReceipt[]
  collaborationAlerts         Alert[]

  @@index([role])
  @@index([isActive])
}

model Patient {
  id                     String                 @id @default(cuid())
  patientCode            String?                @unique
  firstName              String
  middleName             String?
  lastName               String
  fullName               String?
  gender                 Gender                 @default(UNKNOWN)
  dateOfBirth            DateTime
  employeeId             String?
  employeeProfileId      String?                @unique
  phone                  String?
  email                  String?
  medicalRecordNumber    String                 @unique
  nationalId             String?                @unique
  passportNumber         String?                @unique
  organizationId         String?
  departmentId           String?
  contractorId           String?
  contractorCompanyId    String?
  company                String?
  departmentName         String?
  contractorName         String?
  occupation             String?
  jobTitle               String?
  hireDate               DateTime?
  bloodGroup             String?
  maritalStatus          String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  heightCm               Float?
  weightKg               Float?
  bmi                    Float?
  smokingStatus          SmokingStatus          @default(UNKNOWN)
  alcoholStatus          String?
  hypertension           Boolean                @default(false)
  diabetes               Boolean                @default(false)
  dyslipidemia           Boolean                @default(false)
  obesity                Boolean                @default(false)
  ischemicHeartDisease   Boolean                @default(false)
  heartFailure           Boolean                @default(false)
  arrhythmiaHistoryFlag  Boolean                @default(false)
  previousMI             Boolean                @default(false)
  previousCABG           Boolean                @default(false)
  previousPCI            Boolean                @default(false)
  stentsHistory          String?
  familyHistory          String?
  address                String?
  emergencyContact       String?
  allergies              String?
  knownAllergies         String?
  medicalHistory         String?
  medications            String?
  notes                  String?
  status                 PatientStatus          @default(ACTIVE)
  createdById            String?
  updatedById            String?
  archivedAt             DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  organization           Organization?          @relation(fields: [organizationId], references: [id])
  department             Department?            @relation(fields: [departmentId], references: [id])
  contractor             Contractor?            @relation(fields: [contractorId], references: [id])
  contractorCompany      ContractorCompany?     @relation(fields: [contractorCompanyId], references: [id])
  employeeProfile        Employee?              @relation(fields: [employeeProfileId], references: [id])
  cases                  ECGCase[]
  cardiacHistory         CardiacHistory?
  procedureHistories     ProcedureHistory[]
  cardiacProcedures      CardiacProcedure[]
  cardiacImaging         CardiacImaging[]
  medicationHistories    MedicationHistory[]
  documents              ClinicalDocument[]
  fitnessDecisions       FitnessDecision[]
  timelineEvents         TimelineEvent[]
  reports                ClinicalReport[]
  fitnessAssessments     FitnessAssessment[]
  workRestrictions       WorkRestriction[]
  returnToWorkDecisions  ReturnToWorkDecision[]
  documentExtractions    DocumentExtraction[]
  documentIndexes        DocumentSearchIndex[]
  clinicalEcgFiles       ECGFile[]              @relation("PatientECGFiles")
  clinicalAlerts         ECGClinicalAlert[]
  telecardiologyReviews  TelecardiologyReview[]
  clinicalConversations  ClinicalConversation[]
  patientTrends          PatientTrend[]
  riskAssessments        RiskAssessment[]
  clinicalDecisionAlerts ClinicalAlert[]
  patientConsents        PatientConsent[]
  dataRequests           DataRequest[]
  syncQueueItems         SyncQueue[]
  offlineCaches          OfflineCache[]
  tasks                  Task[]
  conversations          Conversation[]
  collaborationAlerts    Alert[]
  auditLogs              AuditLog[]

  @@unique([organizationId, employeeId])
  @@index([lastName, firstName])
  @@index([employeeId])
  @@index([medicalRecordNumber])
  @@index([organizationId])
  @@index([departmentId])
  @@index([contractorId])
  @@index([contractorCompanyId])
  @@index([archivedAt])
  @@index([patientCode])
  @@index([status])
  @@index([createdById])
}

model Organization {
  id                     String                   @id @default(cuid())
  name                   String
  type                   OrganizationType         @default(COMPANY)
  address                String?
  phone                  String?
  email                  String?
  logo                   String?
  status                 OrganizationStatus       @default(ACTIVE)
  createdAt              DateTime                 @default(now())
  departments            Department[]
  contractors            Contractor[]
  contractorCompanies    ContractorCompany[]
  employees              Employee[]
  patients               Patient[]
  documentExtractions    DocumentExtraction[]
  documentIndexes        DocumentSearchIndex[]
  clinicalEcgFiles       ECGFile[]                @relation("OrganizationECGFiles")
  pacsConnections        PACSConnection[]
  integrationLogs        HospitalIntegrationLog[]
  clinicalAlerts         ECGClinicalAlert[]
  clinicalDecisionAlerts ClinicalAlert[]
  securityEvents         SecurityEvent[]
  patientConsents        PatientConsent[]
  dataRequests           DataRequest[]
  backupJobs             BackupJob[]
  teams                  Team[]
  tasks                  Task[]
  conversations          Conversation[]
  collaborationAlerts    Alert[]

  @@index([name])
  @@index([status])
  @@index([type])
}

model Department {
  id                     String          @id @default(cuid())
  organizationId         String
  name                   String
  organization           Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees              Employee[]
  patients               Patient[]
  clinicalDecisionAlerts ClinicalAlert[]
  teams                  Team[]
  tasks                  Task[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ContractorCompany {
  id                     String             @id @default(cuid())
  organizationId         String
  name                   String
  address                String?
  phone                  String?
  email                  String?
  status                 OrganizationStatus @default(ACTIVE)
  createdAt              DateTime           @default(now())
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees              Employee[]
  patients               Patient[]
  clinicalDecisionAlerts ClinicalAlert[]
  tasks                  Task[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([status])
}

model Employee {
  id                      String                   @id @default(cuid())
  organizationId          String
  departmentId            String
  contractorCompanyId     String?
  employeeId              String
  nationalId              String
  fullName                String
  gender                  Gender                   @default(UNKNOWN)
  dateOfBirth             DateTime
  phone                   String?
  email                   String?
  jobTitle                String?
  employmentStatus        EmploymentStatus         @default(ACTIVE)
  hiringDate              DateTime?
  retirementDate          DateTime?
  medicalFitnessStatus    MedicalFitnessStatus     @default(UNKNOWN)
  workCategory            WorkCategory             @default(MODERATE)
  criticalJob             Boolean                  @default(false)
  shiftWorker             Boolean                  @default(false)
  drivingDuty             Boolean                  @default(false)
  workAtHeight            Boolean                  @default(false)
  confinedSpace           Boolean                  @default(false)
  heavyEquipmentOperator  Boolean                  @default(false)
  offshoreWorker          Boolean                  @default(false)
  firefighter             Boolean                  @default(false)
  emergencyResponder      Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  organization            Organization             @relation(fields: [organizationId], references: [id])
  department              Department               @relation(fields: [departmentId], references: [id])
  contractorCompany       ContractorCompany?       @relation(fields: [contractorCompanyId], references: [id])
  patient                 Patient?
  occupationalRiskProfile OccupationalRiskProfile?
  fitnessAssessments      FitnessAssessment[]
  workRestrictions        WorkRestriction[]
  returnToWorkDecisions   ReturnToWorkDecision[]

  @@unique([organizationId, employeeId])
  @@unique([nationalId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([contractorCompanyId])
  @@index([employmentStatus])
  @@index([medicalFitnessStatus])
  @@index([workCategory])
  @@index([criticalJob])
  @@index([nationalId])
}

model OccupationalRiskProfile {
  id                   String   @id @default(cuid())
  employeeId           String   @unique
  smoking              Boolean  @default(false)
  diabetes             Boolean  @default(false)
  hypertension         Boolean  @default(false)
  dyslipidemia         Boolean  @default(false)
  obesity              Boolean  @default(false)
  familyHistory        Boolean  @default(false)
  previousMI           Boolean  @default(false)
  previousStroke       Boolean  @default(false)
  occupationalExposure Json?
  riskScore            Int      @default(0)
  highRisk             Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  employee             Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([highRisk])
  @@index([riskScore])
}

model FitnessAssessment {
  id                        String                      @id @default(cuid())
  employeeId                String
  patientId                 String?
